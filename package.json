{
  "name": "vanta-hl",
  "version": "0.1.0",
  "private": true,
  "description": "Vanta: Hyperliquid testnet-first trading bot foundation with state recovery, reconciliation, and persistence.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/run-foundation.ts",
    "foundation:run": "tsx src/cli/run-foundation.ts",
    "reconcile:run": "tsx src/cli/run-reconcile.ts",
    "lint": "eslint .",
    "smoke:execution": "tsx src/cli/testnet-smoke.ts",
    "retention:run": "tsx src/cli/run-retention.ts",
    "state:account": "tsx src/cli/show-account-state.ts",
    "state:orders": "tsx src/cli/show-open-orders.ts",
    "state:risk": "tsx src/cli/show-risk-state.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.2",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.2.3",
    "pino": "^10.3.1",
    "viem": "^2.39.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
